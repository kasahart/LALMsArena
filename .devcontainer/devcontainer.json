{
  "name": "AudioLLMArena (GPU)",
  "build": {
    "dockerfile": "Dockerfile",
    "context": ".."
  },
  "features": {
    "ghcr.io/devcontainers/features/docker-in-docker:2": {}
  },
  // NVIDIA GPU access configuration; --privileged is required for Docker-in-Docker
  "runArgs": [
    "--gpus",
    "all",
    "--shm-size",
    "16g",
    "--privileged"
  ],
  "containerEnv": {
    "CUDA_VISIBLE_DEVICES": "0",
    "PYTHONPATH": "/workspace",
    "VIRTUAL_ENV": "/workspace/venv",
    "UV_PROJECT_ENVIRONMENT": "/workspace/venv",
    "HF_HOME": "/workspace/.cache/huggingface",
    "HF_HUB_CACHE": "/workspace/.cache/huggingface/hub",
    "TRANSFORMERS_CACHE": "/workspace/.cache/huggingface/transformers"
  },
  // VS Code extensions for Python and AI/ML development
  "customizations": {
    "vscode": {
      "extensions": [
        "ms-python.python",
        "ms-python.vscode-pylance",
        "ms-toolsai.jupyter",
        "ms-toolsai.jupyter-keymap",
        "ms-toolsai.jupyter-renderers",
        "ms-toolsai.vscode-jupyter-cell-tags",
        "ms-toolsai.vscode-jupyter-slideshow"
      ],
      "settings": {
        "python.defaultInterpreterPath": "/workspace/venv/bin/python",
        "python.terminal.activateEnvironment": false,
        "editor.formatOnSave": true,
        "editor.rulers": [
          120
        ]
      }
    }
  },
  "workspaceFolder": "/workspace",
  "updateRemoteUserUID": true,
  "mounts": [
    "source=${localWorkspaceFolder},target=/workspace,type=bind,consistency=cached",
    "source=${localEnv:HOME}/.claude,target=/home/vscode/.claude,type=bind,consistency=cached"
  ],
  // Post-creation commands: configure git-lfs without touching repo hooks, then sync dependencies
  "postCreateCommand": "git lfs install --skip-repo && mkdir -p /workspace/.cache/huggingface && uv sync --frozen --no-dev && (test -d /workspace/vendor/moss_audio/.git || (rm -rf /workspace/vendor/moss_audio && git clone https://github.com/OpenMOSS/MOSS-Audio.git /workspace/vendor/moss_audio))",
  // Register nvidia runtime in the DinD Docker daemon on every container start
  "postStartCommand": "sudo sh -lc 'if command -v nvidia-ctk >/dev/null 2>&1 && pidof dockerd >/dev/null 2>&1; then nvidia-ctk runtime configure --runtime=docker && kill -HUP $(pidof dockerd); else echo \"Skipping nvidia runtime registration: nvidia-ctk or dockerd not available\"; fi'",
  "remoteUser": "vscode",
  "containerUser": "vscode"
}